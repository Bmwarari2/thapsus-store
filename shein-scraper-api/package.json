{
  "name": "shein-scraper-api",
  "version": "0.1.0",
  "private": true,
  "description": "Shein UK scraper API — deterministic gbRawData parsing, Bright Data Web Unlocker, GCP",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/main.ts",
    "dev:worker": "tsx watch src/worker/main.ts",
    "scrape": "tsx src/cli/scrape.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:api": "node dist/api/main.js",
    "start:worker": "node dist/worker/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/tasks": "^5.5.0",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
