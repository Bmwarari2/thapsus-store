# ── Bright Data Web Unlocker ──────────────────────────────────────────────────
# Direct-API mode (https://api.brightdata.com/request). Verify the exact request
# options against current Bright Data docs during Phase 0.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=shein_uk

# Hard daily cap on unlocker calls (in-code fuse; zone spend cap is the outer fuse)
SCRAPE_DAILY_BUDGET=500

# ── API auth ──────────────────────────────────────────────────────────────────
# Comma-separated API keys accepted on X-API-Key. v0: plain values from Secret
# Manager; move to hashed per-key records in Firestore when keys multiply.
API_KEYS=

# ── Mode switches ─────────────────────────────────────────────────────────────
# inline  = tasks run in-process (local dev); cloud_tasks = enqueue to GCP
QUEUE_MODE=inline
# memory  = in-process store (local dev); firestore = GCP Firestore
STORE_MODE=memory

# ── GCP (required when QUEUE_MODE=cloud_tasks or STORE_MODE=firestore) ───────
GCP_PROJECT=
TASKS_LOCATION=europe-west2
TASKS_QUEUE=shein-scrape
WORKER_URL=
# Shared secret the worker requires on task pushes (v0; replace with OIDC audience check)
TASK_SECRET=

PORT=8080
