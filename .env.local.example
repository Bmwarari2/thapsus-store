# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Redis (BullMQ job queue) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────
# REQUIRED in production — the API refuses to boot without it.
JWT_SECRET=change_me_to_a_random_64_char_string

# ── Email (Gmail OAuth — already configured) ──────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=noreply@thapsus.uk

# ── M-Pesa Daraja ─────────────────────────────────────────────────────
# MPESA_ENV: 'sandbox' or 'production' (selects the Daraja base URL)
# MPESA_CALLBACK_TOKEN: random secret appended to the callback path —
#   the callback URL Daraja receives is ${MPESA_CALLBACK_URL}/${MPESA_CALLBACK_TOKEN}
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.thapsus.uk/api/v1/payments/mpesa/callback
MPESA_CALLBACK_TOKEN=change_me_to_a_random_token

# ── Oxylabs ───────────────────────────────────────────────────────────
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# ── Image Storage (Cloudflare R2) ──────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thapsus-images
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.thapsus.uk

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
# Comma-separated CORS allowlist. REQUIRED in production.
WEB_BASE_URL=http://localhost:5173
